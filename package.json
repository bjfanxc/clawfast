{
  "private": true,
  "name": "clawfast",
  "description": "A productized desktop admin console for OpenClaw, with bundled and admin-only packaging modes.",
  "version": "1.0.0",
  "license": "MIT",
  "author": "xinrun <bjfanxc@163.com>",
  "homepage": "https://github.com/littleyps/clawfast",
  "bugs": {
    "url": "https://github.com/littleyps/clawfast/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/littleyps/clawfast.git"
  },
  "main": "app/background.js",
  "scripts": {
    "predev": "node scripts/reset-renderer-cache.js",
    "dev": "nextron",
    "bundle:node-runtime": "node scripts/bundle-node-runtime.mjs",
    "bundle:openclaw": "node scripts/bundle-openclaw.mjs",
    "prune:openclaw": "node scripts/prune-openclaw-optional-deps.mjs",
    "typecheck": "tsc -p renderer/tsconfig.typecheck.json --noEmit",
    "prebuild:renderer": "node scripts/reset-renderer-cache.js",
    "build:renderer": "next build renderer",
    "build": "node scripts/run-build-mode.mjs with-openclaw",
    "build:admin": "node scripts/run-build-mode.mjs admin-only",
    "package:win": "node scripts/run-build-mode.mjs with-openclaw --win",
    "package:win:admin": "node scripts/run-build-mode.mjs admin-only --win",
    "package:mac": "node scripts/run-build-mode.mjs with-openclaw --mac",
    "package:mac:admin": "node scripts/run-build-mode.mjs admin-only --mac",
    "package:linux": "node scripts/run-build-mode.mjs with-openclaw --linux",
    "package:linux:admin": "node scripts/run-build-mode.mjs admin-only --linux",
    "release": "node scripts/run-build-mode.mjs with-openclaw",
    "release:admin": "node scripts/run-build-mode.mjs admin-only",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "fs-extra": "^11.3.4",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "openclaw": "2026.3.13",
    "react-i18next": "^16.5.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "autoprefixer": "^10.4.27",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "next": "^14.2.4",
    "nextron": "^9.5.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3"
  }
}
